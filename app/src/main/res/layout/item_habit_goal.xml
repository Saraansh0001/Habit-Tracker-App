<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/bg_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F5F3FF">
                <ImageView
                    android:id="@+id/iv_habit_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_meditation"
                    app:tint="@color/purple_primary" />
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/tv_habit_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Morning Meditation"
                    android:textColor="#1E293B"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_habit_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 of 5x this week"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btn_goal_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:background="@drawable/bg_pill_active"
                android:backgroundTint="#6366F1"
                android:text="@string/done_label"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <ProgressBar
            android:id="@+id/pb_habit_goal"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:progress="20"
            android:progressTint="@color/purple_primary"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tv_percent_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="20% of weekly goal"
            android:textColor="#94A3B8"
            android:textSize="11sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F1F5F9"
            android:layout_marginTop="16dp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/tv_times_per_week"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Times per week: 5x"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Selector UI simplified as dots or small chips for mockup -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:orientation="horizontal">
                <View android:layout_width="16dp" android:layout_height="16dp" android:background="#6366F1" android:layout_marginEnd="4dp" />
                <View android:layout_width="16dp" android:layout_height="16dp" android:background="#6366F1" android:layout_marginEnd="4dp" />
                <View android:layout_width="16dp" android:layout_height="16dp" android:background="#6366F1" android:layout_marginEnd="4dp" />
                <View android:layout_width="16dp" android:layout_height="16dp" android:background="#6366F1" android:layout_marginEnd="4dp" />
                <View android:layout_width="16dp" android:layout_height="16dp" android:background="#6366F1" />
            </LinearLayout>
        </RelativeLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>