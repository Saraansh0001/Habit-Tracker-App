<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main">

    <!-- BLOBS -->
    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_blob_left"
        android:layout_marginStart="-80dp"
        android:layout_marginTop="60dp"/>

    <View
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:background="@drawable/bg_blob_right"
        android:layout_gravity="end"
        android:layout_marginEnd="-80dp"
        android:layout_marginTop="140dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- LOGO -->
            <ImageView
                android:id="@+id/logo"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:background="@drawable/bg_logo"
                android:padding="18dp"
                android:src="@drawable/ic_logo"
                android:elevation="10dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="40dp"/>

            <!-- TITLE -->
            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Discipline Arena"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#2C2C2C"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/subtitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- SUBTITLE -->
            <TextView
                android:id="@+id/subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Build Discipline. Build Yourself."
                android:textSize="14sp"
                android:textColor="#8E8E93"
                android:layout_marginTop="6dp"
                app:layout_constraintTop_toBottomOf="@id/title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- TOGGLE -->
            <LinearLayout
                android:id="@+id/toggle"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:background="@drawable/bg_toggle"
                android:orientation="horizontal"
                android:padding="6dp"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@id/logo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_toggle_active"
                    android:gravity="center"
                    android:text="Log In"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Sign Up"
                    android:textColor="#9E9E9E"/>
            </LinearLayout>

            <!-- EMAIL -->
            <EditText
                android:id="@+id/email"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:hint="you@email.com"
                android:background="@drawable/bg_input"
                android:padding="16dp"
                android:layout_marginTop="28dp"
                app:layout_constraintTop_toBottomOf="@id/toggle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- PASSWORD -->
            <EditText
                android:id="@+id/password"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:hint="Enter password"
                android:background="@drawable/bg_input"
                android:padding="16dp"
                android:inputType="textPassword"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/email"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- FORGOT -->
            <TextView
                android:id="@+id/forgot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Forgot Password?"
                android:textColor="#5B3EFF"
                android:textSize="13sp"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/password"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- LOGIN BUTTON -->
            <Button
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:text="Log In"
                android:elevation="10dp"
                android:textColor="#FFF"
                android:textAllCaps="false"
                android:background="@drawable/bg_button"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/forgot"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</FrameLayout>