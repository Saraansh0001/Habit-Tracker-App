<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F5FB">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Left Circle -->
        <View
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:background="@drawable/circle_left"
            android:alpha="0.6"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:translationX="-40dp"
            android:translationY="30dp"/>

        <!-- Right Circle -->
        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:background="@drawable/circle_right"
            android:alpha="0.7"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:translationX="40dp"
            android:translationY="120dp"/>

        <!-- Logo -->
        <TextView
            android:id="@+id/logo"
            android:text="⚡"
            android:textSize="28sp"
            android:textColor="#FFD84D"
            android:gravity="center"
            android:background="@drawable/logo_bg"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:elevation="6dp"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="120dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Title -->
        <TextView
            android:id="@+id/title"
            android:text="Discipline Arena"
            android:textStyle="bold"
            android:textSize="24sp"
            android:textColor="#2B2E38"
            app:layout_constraintTop_toBottomOf="@id/logo"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Subtitle -->
        <TextView
            android:text="Build Discipline. Build Yourself."
            android:textColor="#7A7E87"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Login Signup Toggle -->
        <LinearLayout
            android:id="@+id/toggle"
            android:orientation="horizontal"
            android:background="#ECECEC"
            android:padding="4dp"
            android:layout_marginTop="40dp"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:text="Log In"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#FFFFFF"
                android:textColor="#2B2E38"/>

            <Button
                android:text="Sign Up"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#ECECEC"
                android:textColor="#7A7E87"/>
        </LinearLayout>

        <!-- Email Label -->
        <TextView
            android:id="@+id/emailLabel"
            android:text="Email"
            android:textColor="#6B7280"
            android:textSize="14sp"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toBottomOf="@id/toggle"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Email Input -->
        <EditText
            android:id="@+id/email"
            android:hint="you@email.com"
            android:background="@drawable/input_bg"
            android:padding="14dp"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/emailLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <!-- Password Label -->
        <TextView
            android:id="@+id/passwordLabel"
            android:text="Password"
            android:textColor="#6B7280"
            android:textSize="14sp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/email"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Password Input -->
        <EditText
            android:id="@+id/password"
            android:hint="Enter password"
            android:background="@drawable/input_bg"
            android:padding="14dp"
            android:inputType="textPassword"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/passwordLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <!-- Forgot Password -->
        <TextView
            android:text="Forgot Password?"
            android:textColor="#4F46E5"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/password"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Login Button -->
        <Button
            android:text="Log In"
            android:textColor="#FFFFFF"
            android:background="@drawable/login_button"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/password"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="0dp"
            android:layout_height="55dp"/>

        <!-- Divider -->
        <TextView
            android:text="or continue with"
            android:textColor="#6B7280"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/password"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Google Button -->
        <Button
            android:text="Continue with Google"
            android:layout_marginTop="14dp"
            android:background="@drawable/input_bg"
            app:layout_constraintTop_toBottomOf="@id/password"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="0dp"
            android:layout_height="55dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>