<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- blob top left purple -->
    <ImageView
        android:id="@+id/blob_top_left"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:src="@drawable/blob_purple"
        android:alpha="0.3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="-40dp"
        android:layout_marginStart="-60dp" />

    <!-- blob right teal -->
    <ImageView
        android:id="@+id/blob_right"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/blob_teal"
        android:alpha="0.3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="100dp"
        android:layout_marginEnd="-50dp" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="60dp"
            android:paddingBottom="32dp">

            <!-- app icon card -->
            <androidx.cardview.widget.CardView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center_horizontal"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/purple_primary">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_bolt"
                    app:tint="@android:color/white" />

            </androidx.cardview.widget.CardView>

            <!-- title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:text="Discipline Arena"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark" />

            <!-- subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:text="Build Discipline. Build Yourself."
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <!-- tab toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_tab_container"
                android:padding="4dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tab_login"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Log In"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:background="@drawable/bg_tab_selected" />

                <TextView
                    android:id="@+id/tab_sign_up"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Sign Up"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

            <!-- Full Name (Hidden by default for Login) -->
            <LinearLayout
                android:id="@+id/ll_full_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Full Name"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    style="@style/input_field_style">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_name"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:hint="Enter your name"
                        android:inputType="textPersonName"
                        android:textSize="14sp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="@drawable/bg_input_field" />

                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- email label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Email"
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:textStyle="bold" />

            <!-- email input -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                style="@style/input_field_style">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="you@email.com"
                    android:inputType="textEmailAddress"
                    android:textSize="14sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/bg_input_field" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- password label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Password"
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:textStyle="bold" />

            <!-- password input -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                style="@style/input_field_style"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/text_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Enter password"
                    android:inputType="textPassword"
                    android:textSize="14sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="48dp"
                    android:background="@drawable/bg_input_field" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- forgot password -->
            <TextView
                android:id="@+id/tv_forgot_password"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="12dp"
                android:text="Forgot Password?"
                android:textSize="14sp"
                android:textColor="@color/purple_primary"
                android:textStyle="bold" />

            <!-- submit button -->
            <Button
                android:id="@+id/btn_submit"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:text="Log In"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_btn_primary"
                android:textAllCaps="false" />

            <!-- or continue with -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="24dp">
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="@color/input_border" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:text="or continue with"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary" />
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="@color/input_border" />
            </LinearLayout>

            <!-- google button -->
            <Button
                android:id="@+id/btn_google"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="20dp"
                android:text="Continue with Google"
                android:textSize="16sp"
                android:textColor="@color/text_dark"
                android:background="@drawable/bg_btn_google"
                android:drawableStart="@drawable/ic_google"
                android:drawablePadding="-20dp"
                android:paddingStart="24dp"
                android:textAllCaps="false" />

            <!-- terms -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:text="By continuing, you agree to our Terms &amp; Privacy Policy"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:gravity="center" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>