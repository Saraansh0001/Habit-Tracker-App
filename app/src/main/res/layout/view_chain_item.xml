<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical">
    <androidx.cardview.widget.CardView
        android:layout_width="44dp"
        android:layout_height="44dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#F5F3FF">
        <ImageView
            android:id="@+id/iv_chain_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_nav_arena"
            app:tint="@color/purple_primary"
            android:contentDescription="@string/rank_icon_desc" />
    </androidx.cardview.widget.CardView>
    <TextView
        android:id="@+id/tv_chain_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Meditate"
        android:textSize="9sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="4dp" />
    <TextView
        android:id="@+id/tv_chain_percent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="78%"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="@color/purple_primary" />
</LinearLayout>