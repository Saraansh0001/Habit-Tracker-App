<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_mood_header_gradient"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/iv_back_mood"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_back"
                        app:tint="@android:color/white"
                        android:background="?attr/selectableItemBackgroundBorderless" />

                    <TextView
                        android:id="@+id/tv_mood_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mood Tracker 😊"
                        android:textColor="@android:color/white"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_toEndOf="@id/iv_back_mood"
                        android:layout_marginStart="12dp"
                        android:layout_centerVertical="false"
                        android:layout_alignTop="@id/iv_back_mood" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Log daily mood, spot patterns with habits"
                        android:textColor="#F0F0F0"
                        android:textSize="12sp"
                        android:layout_below="@id/tv_mood_title"
                        android:layout_alignStart="@id/tv_mood_title"
                        android:layout_marginTop="2dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_below="@id/tv_mood_title"
                        android:layout_marginTop="32dp"
                        android:weightSum="3">

                        <!-- Stat 1 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_tab_container"
                            android:backgroundTint="#40FFFFFF"
                            android:padding="12dp"
                            android:layout_marginEnd="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3.9"
                                android:textColor="@android:color/white"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="7-day avg"
                                android:textColor="#E0E0E0"
                                android:textSize="10sp" />
                        </LinearLayout>

                        <!-- Stat 2 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_tab_container"
                            android:backgroundTint="#40FFFFFF"
                            android:padding="12dp"
                            android:layout_marginHorizontal="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="7"
                                android:textColor="@android:color/white"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total logs"
                                android:textColor="#E0E0E0"
                                android:textSize="10sp" />
                        </LinearLayout>

                        <!-- Stat 3 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_tab_container"
                            android:backgroundTint="#40FFFFFF"
                            android:padding="12dp"
                            android:layout_marginStart="6dp">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_nav_arena"
                                app:tint="#FFEB3B" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Today"
                                android:textColor="#E0E0E0"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Mood Selection Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bg_white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="How are you feeling today?"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap an emoji to log your current mood"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="24dp"
                        android:weightSum="5">

                        <!-- Emojis -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😣" android:textSize="32sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rough" android:textSize="10sp" android:textColor="#FF5252" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😔" android:textSize="32sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sad" android:textSize="10sp" android:textColor="#FF9800" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😐" android:textSize="32sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="OK" android:textSize="10sp" android:textColor="#9E9E9E" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😊" android:textSize="32sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Good" android:textSize="10sp" android:textColor="#4CAF50" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🤩" android:textSize="32sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Amazing" android:textSize="10sp" android:textColor="#6200EE" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <Button
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="24dp"
                        android:text="Log My Mood"
                        android:textAllCaps="false"
                        android:textColor="@color/text_hint"
                        android:backgroundTint="@color/bg_light"
                        app:cornerRadius="12dp"
                        android:enabled="false" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Mood Trend Chart -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bg_white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📉 7-Day Mood Trend"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Higher = happier"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />

                    <!-- Placeholder for Bar Chart -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        android:weightSum="7">
                        <View android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1" android:background="#6B3FD4" android:layout_marginHorizontal="4dp"/>
                        <View android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1" android:background="#6B3FD4" android:layout_marginHorizontal="4dp"/>
                        <View android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:background="#FFC107" android:layout_marginHorizontal="4dp"/>
                        <View android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:background="#6B3FD4" android:layout_marginHorizontal="4dp"/>
                        <View android:layout_width="0dp" android:layout_height="90dp" android:layout_weight="1" android:background="#6B3FD4" android:layout_marginHorizontal="4dp"/>
                        <View android:layout_width="0dp" android:layout_height="65dp" android:layout_weight="1" android:background="#4CAF50" android:layout_marginHorizontal="4dp"/>
                        <View android:layout_width="0dp" android:layout_height="85dp" android:layout_weight="1" android:background="#6B3FD4" android:layout_marginHorizontal="4dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:weightSum="7">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Mar 30" android:textSize="8sp" android:gravity="center"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Mar 31" android:textSize="8sp" android:gravity="center"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Apr 1" android:textSize="8sp" android:gravity="center"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Apr 2" android:textSize="8sp" android:gravity="center"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Apr 3" android:textSize="8sp" android:gravity="center"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Apr 4" android:textSize="8sp" android:gravity="center"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Apr 5" android:textSize="8sp" android:gravity="center"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Mood Insights Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bg_white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔍 Mood Insights"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Which habits make you happiest?"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />

                    <!-- Insights List Placeholder -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp">

                        <!-- Item 1 -->
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp">
                            <TextView android:id="@+id/tv_rank_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="#1" android:textColor="@color/text_hint" android:textSize="12sp" android:layout_centerVertical="true"/>
                            <ImageView android:id="@+id/iv_insight_1" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_nav_arena" android:layout_toEndOf="@id/tv_rank_1" android:layout_marginStart="12dp" android:layout_centerVertical="true"/>
                            <TextView android:id="@+id/tv_insight_title_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Morning Meditation" android:textColor="@color/text_dark" android:textSize="13sp" android:layout_toEndOf="@id/iv_insight_1" android:layout_marginStart="12dp" android:layout_centerVertical="true" android:textStyle="bold"/>
                            <ProgressBar style="?android:attr/progressBarStyleHorizontal" android:layout_width="80dp" android:layout_height="4dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:progress="100" android:progressTint="#4CAF50"/>
                        </RelativeLayout>

                        <!-- Item 2 -->
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp">
                            <TextView android:id="@+id/tv_rank_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="#2" android:textColor="@color/text_hint" android:textSize="12sp" android:layout_centerVertical="true"/>
                            <ImageView android:id="@+id/iv_insight_2" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_nav_home" android:layout_toEndOf="@id/tv_rank_2" android:layout_marginStart="12dp" android:layout_centerVertical="true"/>
                            <TextView android:id="@+id/tv_insight_title_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Drink 8 Glasses" android:textColor="@color/text_dark" android:textSize="13sp" android:layout_toEndOf="@id/iv_insight_2" android:layout_marginStart="12dp" android:layout_centerVertical="true" android:textStyle="bold"/>
                            <ProgressBar style="?android:attr/progressBarStyleHorizontal" android:layout_width="80dp" android:layout_height="4dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:progress="80" android:progressTint="#4CAF50"/>
                        </RelativeLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/bg_insight_note"
                        android:padding="12dp"
                        android:text="✨ Insight: Your mood is highest when you complete Morning Meditation — this habit appears in 100% of your great mood days!"
                        android:textColor="#FBC02D"
                        android:textSize="11sp"
                        android:textStyle="italic" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>