<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/analytics_title"
                android:textColor="@color/text_dark"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/analytics_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:layout_marginTop="4dp" />

            <!-- Streak Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_streak"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="8dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp"
                    android:background="@drawable/bg_header_gradient">

                    <TextView
                        android:id="@+id/tv_streak_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/current_streak_label"
                        android:textColor="#E0E0E0"
                        android:textSize="14sp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        android:layout_marginTop="8dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_streak_label"
                        app:layout_constraintStart_toStartOf="parent">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/streak_days_count"
                            android:textColor="@android:color/white"
                            android:textSize="48sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/days_label"
                            android:textColor="#E0E0E0"
                            android:textSize="18sp"
                            android:layout_marginStart="8dp"
                            android:layout_marginBottom="10dp" />
                    </LinearLayout>

                    <androidx.cardview.widget.CardView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        app:cardCornerRadius="32dp"
                        app:cardBackgroundColor="#4DFFFFFF"
                        app:cardElevation="0dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_bolt"
                            app:tint="#FFC107"
                            android:contentDescription="@string/flame_icon_desc" />
                    </androidx.cardview.widget.CardView>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Weekly Progress -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_weekly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/weekly_progress_title"
                            android:textColor="@color/text_dark"
                            android:textStyle="bold"
                            android:textSize="16sp" />
                        <TextView
                            android:id="@+id/tv_this_week"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="@string/this_week_label"
                            android:textColor="@color/purple_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true" />
                    </RelativeLayout>

                    <!-- Mock Bar Chart -->
                    <LinearLayout
                        android:id="@+id/ll_bar_chart"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="24dp"
                        android:gravity="bottom"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <include layout="@layout/view_bar_chart_item" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                        <include layout="@layout/view_bar_chart_item" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                        <include layout="@layout/view_bar_chart_item" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                        <include layout="@layout/view_bar_chart_item" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                        <include layout="@layout/view_bar_chart_item" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                        <include layout="@layout/view_bar_chart_item" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                        <include layout="@layout/view_bar_chart_item" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Monthly Consistency -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_monthly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/monthly_consistency_title"
                            android:textColor="@color/text_dark"
                            android:textStyle="bold"
                            android:textSize="16sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="@string/consistency_increase_mock"
                            android:textColor="#10B981"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <!-- Mock Line Chart Placeholder -->
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginTop="24dp"
                        android:src="@drawable/bg_tab_container"
                        android:alpha="0.2"
                        android:contentDescription="@string/line_chart_desc" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:baselineAligned="false">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/week_2_short" android:gravity="center" android:textSize="11sp" android:textColor="@color/text_secondary" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/week_3_short" android:gravity="center" android:textSize="11sp" android:textColor="@color/text_secondary" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/week_4_short" android:gravity="center" android:textSize="11sp" android:textColor="@color/text_secondary" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/week_5_short" android:gravity="center" android:textSize="11sp" android:textColor="@color/text_secondary" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/week_6_short" android:gravity="center" android:textSize="11sp" android:textColor="@color/text_secondary" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Insight Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:id="@+id/ll_chains_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ripple_chain_insight_title"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/personal_cascade_subtitle"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />

                    <!-- Chains -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp">

                        <include layout="@layout/view_insight_chain" />
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/input_border" android:layout_marginVertical="16dp" />
                        <include layout="@layout/view_insight_chain" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Habit Completion -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_completion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/habit_completion_title"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold"
                        android:textSize="16sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="100dp"
                            android:layout_height="100dp">
                            <ProgressBar
                                android:id="@+id/pb_completion"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:indeterminate="false"
                                android:progress="0"
                                android:max="100"
                                android:progressDrawable="@drawable/circle_outline_analytics"
                                style="?android:attr/progressBarStyleHorizontal" />
                            <TextView
                                android:id="@+id/tv_completion_percent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="@string/zero_percent"
                                android:textStyle="bold"
                                android:textSize="18sp"
                                android:textColor="@color/text_dark" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="32dp">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                                <View android:layout_width="12dp" android:layout_height="12dp" android:background="@color/purple_primary" android:layout_marginEnd="8dp" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Completed (72%)" android:textSize="12sp" android:textColor="@color/text_secondary" />
                            </LinearLayout>
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
                                <View android:layout_width="12dp" android:layout_height="12dp" android:background="@color/input_border" android:layout_marginEnd="8dp" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Remaining (28%)" android:textSize="12sp" android:textColor="@color/text_secondary" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Text Insights -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:id="@+id/ll_insights_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/insights_section_title"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold"
                        android:textSize="16sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp">
                        <include layout="@layout/item_insight_text" />
                        <include layout="@layout/item_insight_text" />
                        <include layout="@layout/item_insight_text" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>