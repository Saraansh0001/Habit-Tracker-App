<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Top Section with Back Button and Title -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_back"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_revert"
                        app:tint="@color/text_dark" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Create Challenge"
                    android:textColor="@color/text_dark"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Challenge Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Challenge Name"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:layout_marginTop="32dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/white">
                <EditText
                    android:id="@+id/et_challenge_name"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="e.g., 30-Day Meditation"
                    android:textColorHint="@color/text_hint"
                    android:paddingHorizontal="20dp"
                    android:textSize="15sp"
                    android:importantForAutofill="no"
                    android:inputType="text" />
            </androidx.cardview.widget.CardView>

            <!-- Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/white">
                <EditText
                    android:id="@+id/et_description"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Describe your challenge..."
                    android:textColorHint="@color/text_hint"
                    android:padding="20dp"
                    android:gravity="top"
                    android:textSize="15sp"
                    android:importantForAutofill="no"
                    android:inputType="textMultiLine" />
            </androidx.cardview.widget.CardView>

            <!-- Habit Type -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Habit Type"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_habit_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:singleSelection="true">
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_fitness"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fitness"
                    app:chipBackgroundColor="@color/bg_white"
                    android:textColor="@color/text_secondary" />
                <com.google.android.material.chip.Chip
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Meditation"
                    app:chipBackgroundColor="@color/bg_white"
                    android:textColor="@color/text_secondary" />
                <com.google.android.material.chip.Chip
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Study"
                    app:chipBackgroundColor="@color/bg_white"
                    android:textColor="@color/text_secondary" />
                <com.google.android.material.chip.Chip
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Productivity"
                    app:chipBackgroundColor="@color/bg_white"
                    android:textColor="@color/text_secondary" />
                <com.google.android.material.chip.Chip
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Health"
                    app:chipBackgroundColor="@color/bg_white"
                    android:textColor="@color/text_secondary" />
                <com.google.android.material.chip.Chip
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Custom"
                    app:chipBackgroundColor="@color/bg_white"
                    android:textColor="@color/text_secondary" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Duration -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Duration"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_duration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:singleSelection="true">
                <com.google.android.material.chip.Chip
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7d"
                    android:paddingHorizontal="24dp"
                    app:chipBackgroundColor="@color/bg_white"
                    android:textColor="@color/text_secondary" />
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_14d"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="14d"
                    android:paddingHorizontal="24dp"
                    app:chipBackgroundColor="@color/bg_white"
                    android:textColor="@color/text_secondary" />
                <com.google.android.material.chip.Chip
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="21d"
                    android:paddingHorizontal="24dp"
                    app:chipBackgroundColor="@color/bg_white"
                    android:textColor="@color/text_secondary" />
                <com.google.android.material.chip.Chip
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30d"
                    android:paddingHorizontal="24dp"
                    app:chipBackgroundColor="@color/bg_white"
                    android:textColor="@color/text_secondary" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Max Participants -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Max Participants"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/white">
                <EditText
                    android:id="@+id/et_participants"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="50"
                    android:textColorHint="@color/text_hint"
                    android:paddingHorizontal="20dp"
                    android:textSize="15sp"
                    android:importantForAutofill="no"
                    android:inputType="number" />
            </androidx.cardview.widget.CardView>

            <!-- Public Toggle -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/white">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <ImageView
                        android:id="@+id/iv_public"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_compass"
                        app:tint="@color/purple_primary"
                        android:layout_centerVertical="true" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toEndOf="@id/iv_public"
                        android:layout_marginStart="16dp"
                        android:layout_centerVertical="true">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Public"
                            android:textColor="@color/text_dark"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Anyone can join"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="true"
                        app:thumbTint="@color/purple_primary"
                        app:trackTint="@color/purple_light" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Create Button -->
            <Button
                android:id="@+id/btn_create_final"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="120dp"
                android:text="Create Challenge"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/purple_primary"
                app:cornerRadius="20dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>