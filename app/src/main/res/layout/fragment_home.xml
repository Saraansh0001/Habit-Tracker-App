<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="120dp">

            <!-- Header Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="8dp"
                app:cardMaxElevation="12dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp"
                    android:background="@drawable/bg_header_gradient">

                    <TextView
                        android:id="@+id/tv_greeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/greeting"
                        android:textColor="#E0E0E0"
                        android:textSize="14sp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/tv_user_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/user_name_default"
                        android:textColor="@android:color/white"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toBottomOf="@id/tv_greeting"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="4dp" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="#4DFFFFFF"
                        app:cardElevation="0dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:orientation="horizontal"
                            android:gravity="center"
                            tools:ignore="UseCompoundDrawables">
                            <View android:layout_width="12dp" android:layout_height="12dp" android:background="@android:color/holo_orange_light" android:layout_marginEnd="6dp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12" android:textColor="@android:color/white" android:textStyle="bold" tools:ignore="HardcodedText" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Progress Circle -->
                    <FrameLayout
                        android:id="@+id/fl_progress"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_marginTop="24dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_user_name"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <ProgressBar
                            android:id="@+id/pb_main_progress"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:indeterminate="false"
                            android:progressDrawable="@drawable/circle_outline"
                            android:progress="50"
                            style="?android:attr/progressBarStyleHorizontal" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:gravity="center"
                            tools:ignore="UselessParent">
                            <TextView
                                android:id="@+id/tv_progress_percentage"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="50%"
                                android:textColor="@android:color/white"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/completed_label"
                                android:textColor="#B3FFFFFF"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tv_streak_val"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12"
                        android:textColor="@android:color/white"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/fl_progress"
                        app:layout_constraintTop_toTopOf="@id/fl_progress"
                        android:layout_marginStart="32dp"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/day_streak_label"
                        android:textColor="#E0E0E0"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="@id/tv_streak_val"
                        app:layout_constraintTop_toBottomOf="@id/tv_streak_val" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

            <!-- Search Field -->
            <EditText
                android:id="@+id/et_search_habits"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_input_field"
                android:hint="@string/search_habits_hint"
                android:paddingHorizontal="20dp"
                android:inputType="text"
                android:maxLines="1"
                android:autofillHints="none" />

            <!-- Categories -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_categories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:singleSelection="true"
                app:chipSpacingHorizontal="8dp">
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:checked="true"
                    tools:ignore="HardcodedText" />
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fitness"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    tools:ignore="HardcodedText" />
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Study"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    tools:ignore="HardcodedText" />
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Meditation"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    tools:ignore="HardcodedText" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Features Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/features_title"
                    android:textColor="@color/text_dark"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_all_features"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="@string/all_link"
                    android:textColor="@color/purple_primary"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </RelativeLayout>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:columnCount="4"
                android:alignmentMode="alignMargins">

                <!-- Feature Items (Mocked) -->
                <!-- Streaks -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center" android:layout_marginBottom="16dp" tools:ignore="UseCompoundDrawables">
                    <androidx.cardview.widget.CardView android:layout_width="60dp" android:layout_height="60dp" app:cardCornerRadius="16dp" app:cardBackgroundColor="@android:color/white" app:cardElevation="2dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_bolt" app:tint="@color/purple_primary" android:contentDescription="@string/feature_streaks" />
                    </androidx.cardview.widget.CardView>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/feature_streaks" android:textSize="12sp" android:layout_marginTop="8dp" />
                </LinearLayout>

                <!-- Timer -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center" tools:ignore="UseCompoundDrawables">
                    <androidx.cardview.widget.CardView android:layout_width="60dp" android:layout_height="60dp" app:cardCornerRadius="16dp" app:cardBackgroundColor="@android:color/white" app:cardElevation="2dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_bolt" app:tint="#FF5252" android:contentDescription="@string/feature_timer" />
                    </androidx.cardview.widget.CardView>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/feature_timer" android:textSize="12sp" android:layout_marginTop="8dp" />
                </LinearLayout>

                <!-- Goals -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center" tools:ignore="UseCompoundDrawables">
                    <androidx.cardview.widget.CardView android:layout_width="60dp" android:layout_height="60dp" app:cardCornerRadius="16dp" app:cardBackgroundColor="@android:color/white" app:cardElevation="2dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_bolt" app:tint="#4CAF50" android:contentDescription="@string/feature_goals" />
                    </androidx.cardview.widget.CardView>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/feature_goals" android:textSize="12sp" android:layout_marginTop="8dp" />
                </LinearLayout>

                <!-- Journal -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center" tools:ignore="UseCompoundDrawables">
                    <androidx.cardview.widget.CardView android:layout_width="60dp" android:layout_height="60dp" app:cardCornerRadius="16dp" app:cardBackgroundColor="@android:color/white" app:cardElevation="2dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_bolt" app:tint="#2196F3" android:contentDescription="@string/feature_journal" />
                    </androidx.cardview.widget.CardView>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/feature_journal" android:textSize="12sp" android:layout_marginTop="8dp" />
                </LinearLayout>

            </GridLayout>

            <!-- Habits Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/todays_habits_title"
                    android:textColor="@color/text_dark"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_see_all_habits"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="@string/see_all_link"
                    android:textColor="@color/purple_primary"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_habits_home"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_habit_home" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_habit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_input_add"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@android:color/white"
        app:backgroundTint="@color/purple_primary"
        app:fabSize="normal"
        android:contentDescription="@string/create_challenge" />

</androidx.constraintlayout.widget.ConstraintLayout>