<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- Header Section -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:background="@drawable/bg_header_gradient" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="24dp"
                    android:layout_marginTop="40dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_profile_pic"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/user_avatar_placeholder"
                        app:shapeAppearanceOverlay="@style/CircleAppearance"
                        android:padding="2dp"
                        android:background="@android:color/white"
                        android:contentDescription="@string/nav_profile" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/user_name_default"
                            android:textColor="@android:color/white"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/user_rank"
                            android:textColor="@color/purple_light"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_stat_badge"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="6dp"
                                android:gravity="center"
                                tools:ignore="UseCompoundDrawables">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🔥 12 streak"
                                    android:textColor="@android:color/white"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    tools:ignore="HardcodedText" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_stat_badge"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="6dp"
                                android:gravity="center"
                                tools:ignore="UseCompoundDrawables">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="⚡ 2,450 XP"
                                    android:textColor="@android:color/white"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    tools:ignore="HardcodedText" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:layout_marginTop="-20dp">

                <!-- Badges Section -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="20dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <RelativeLayout
                            android:id="@+id/rl_profile_badges"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/badges_title"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark"
                                tools:text="🏅 Badges (4)" />
                            <TextView
                                android:id="@+id/tv_see_all_badges"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="@string/see_all_link"
                                android:textColor="@color/purple_primary"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true"/>
                        </RelativeLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="12dp"
                            android:gravity="center">
                            <ImageView android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/ic_badge_1" android:layout_marginHorizontal="8dp" android:contentDescription="@string/badges_title" />
                            <ImageView android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/ic_badge_2" android:layout_marginHorizontal="8dp" android:contentDescription="@string/badges_title" />
                            <ImageView android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/ic_badge_3" android:layout_marginHorizontal="8dp" android:contentDescription="@string/badges_title" />
                            <ImageView android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/ic_badge_4" android:layout_marginHorizontal="8dp" android:contentDescription="@string/badges_title" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Features Section -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/your_features_title"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"/>
                    <TextView
                        android:id="@+id/tv_all_features"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="@string/all_features_link"
                        android:textColor="@color/purple_primary"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"/>
                </RelativeLayout>

                <GridLayout
                    android:id="@+id/features_grid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:layout_marginBottom="24dp">
                </GridLayout>

                <!-- Stats Section -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="24dp">
                    <LinearLayout
                        android:id="@+id/stats_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/your_stats_title"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:layout_marginBottom="16dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Settings Section -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="24dp">
                    <LinearLayout
                        android:id="@+id/actions_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Added manually to resolve code referencing these IDs -->
                        <RelativeLayout
                            android:id="@+id/rl_profile_account_settings"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/account_section"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark" />
                        </RelativeLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_notifications_profile"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp"
                            android:text="@string/notifications"
                            android:textColor="@color/text_dark" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_dark_mode_profile"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp"
                            android:text="@string/dark_mode"
                            android:textColor="@color/text_dark" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Logout Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_logout"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="@string/log_out"
                    android:textColor="#FF4B4B"
                    app:strokeColor="#FFEDED"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_logout"
                    app:iconGravity="textStart"
                    app:iconTint="#FF4B4B"
                    android:layout_marginBottom="20dp"
                    android:backgroundTint="#FFEDED"
                    android:contentDescription="@string/log_out" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>